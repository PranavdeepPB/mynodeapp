pipeline {
    agent any

    environment {
        DOCKER_IMAGE      = "pranavdeeppb/mynodeapp"
        DOCKER_TAG        = "${BUILD_NUMBER}"
        DOCKER_HUB_CREDS  = credentials('dockerhub-creds')   
        AWS_REGION        = "ap-south-1"                      
        EKS_CLUSTER_NAME  = "nodeapp"          
        K8S_NAMESPACE     = "default"
    }

    stages {

        stage('Checkout') {
            steps {
                echo ' Pulling code from GitHub...'
                git branch: 'master', 
                    url: 'https://github.com/PranavdeepPB/mynodeapp.git', 
                    credentialsId: 'github-creds'
            }
        }

        stage('Build') {
            steps {
                echo ' Building Docker image...'
                sh """
                    docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} .
                    docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest
                """
            }
        }

        stage('Push') {
            steps {
                echo ' Pushing image to Docker Hub...'
                sh """
                    echo ${DOCKER_HUB_CREDS_PSW} | docker login -u ${DOCKER_HUB_CREDS_USR} --password-stdin
                    docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }

        stage('Configure kubectl') {
            steps {
                echo 'Connecting to EKS cluster...'
                withAWS(credentials: 'aws-creds', region: "${AWS_REGION}") {
                    sh """
                        aws eks update-kubeconfig \
                            --region ${AWS_REGION} \
                            --name ${EKS_CLUSTER_NAME}
                    """
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                echo ' Deploying to EKS...'
                withAWS(credentials: 'aws-creds', region: "${AWS_REGION}") {
                    sh """
                        # Apply deployment and service
                        kubectl apply -f deployment.yaml -n ${K8S_NAMESPACE}
                        kubectl apply -f service.yaml   -n ${K8S_NAMESPACE}

                        # Update the image to the new build tag
                        kubectl set image deployment/mynodeapp \
                            mynodeapp=${DOCKER_IMAGE}:${DOCKER_TAG} \
                            -n ${K8S_NAMESPACE}

                        # Wait until rollout completes
                        kubectl rollout status deployment/mynodeapp \
                            -n ${K8S_NAMESPACE} \
                            --timeout=120s
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                echo ' Verifying deployment...'
                withAWS(credentials: 'aws-creds', region: "${AWS_REGION}") {
                    sh """
                        kubectl get pods -n ${K8S_NAMESPACE} -l app=mynodeapp
                        kubectl get svc  -n ${K8S_NAMESPACE} mynodeapp-service
                    """
                }
            }
        }
    }

    post {
        success {
            echo ' Pipeline succeeded! App is live on EKS.'
        }
        failure {
            echo ' Pipeline failed. Check logs above.'
        }
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} || true"
        }
    }
}
